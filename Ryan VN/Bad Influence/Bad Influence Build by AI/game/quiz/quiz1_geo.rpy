# ==========================================
# LABEL UTAMA QUIZ 1
# ==========================================

label quiz1_start:
    $ _quiz_reset()

    # Tentukan difficulty dari sanity
    if sanity >= 55:
        $ _q1_qs    = _q1_easy
        $ _q1_narr  = _q1_easy_narr
        $ _q1_time  = 60
        $ _q1_name  = "Kuis Geografi"
    elif sanity >= 30:
        $ _q1_qs    = _q1_medium
        $ _q1_narr  = _q1_medium_narr
        $ _q1_time  = 60
        $ _q1_name  = "Kuis Geografi"
    else:
        $ _q1_qs    = _q1_hard
        $ _q1_narr  = _q1_hard_narr
        $ _q1_time  = 30
        $ _q1_name  = "Kuis Geografi — Tingkat Lanjut"

    call screen quiz_screen(_q1_name, _q1_qs, _q1_time, _q1_narr)
    $ _q1_completed = _return

    # --- Hitung Skor & Update Stats ---
    $ (_q1_c, _q1_t, _q1_pct) = _quiz_get_result()
    $ quiz1_score = _q1_pct

    # Update stats silently
    if _q1_pct >= 80:
        $ sanity += 5
        $ quiz_passed = True
    elif _q1_pct < 50:
        $ sanity -= 5
        $ quiz_passed = False
    else:
        $ quiz_passed = True

    "Kuis telah selesai. Pak Guru mengumpulkan lembar jawaban."
    "(Narasi Internal) Sudah selesai. Aku tidak tahu berapa yang kujawab benar. Tunggu saja."

    return
